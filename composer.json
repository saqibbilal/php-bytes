{
    "name": "saqib/php-bytes",
    "description": "Dynamic laboratory for PHP algorithms, patterns, and SQL optimization.",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Saqib\\PhpBytes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Saqib Bilal",
            "email": "saqib_bilal786@yahoo.com"
        }
    ],
    "minimum-stability": "stable",
    "require-dev": {
        "pestphp/pest": "^4.6"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    }
}
